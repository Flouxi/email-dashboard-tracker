# Secret used to sign tracking tokens (open/click). Any long random string.
TRACKING_SECRET=replace-with-a-long-random-string

# Password required to view the dashboard / call /api/stats.
# Leave unset only for local testing — never leave it unset in production.
DASHBOARD_SECRET=replace-with-a-dashboard-password

# Only needed locally if you want to test against Vercel KV directly.
# On Vercel itself these are set automatically when you attach a KV store.
KV_REST_API_URL=
KV_REST_API_TOKEN=
